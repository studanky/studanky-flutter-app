<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Route incoming Universal Links through Flutter so go_router resolves
	     them (e.g. https://studankyapp.cz/s/{id} -> /map/spring/{id}). -->
	<key>FlutterDeepLinkingEnabled</key>
	<true/>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Studánky</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>cs</string>
	</array>
	<key>CFBundleName</key>
	<string>Studánky</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<!-- map_launcher: schemes we may query to detect installed maps apps for the
		     "show spring on map" picker. Declaring a scheme only grants permission to
		     ask whether it is installed (canOpenURL) — apps the user does not have
		     never appear in the picker, and we show every maps app they do have.
		     Covers the EU/global apps a user might realistically have; Apple Maps
		     needs no scheme. -->
		<string>szn-mapy</string>
		<string>osmandmaps</string>
		<string>mapswithme</string>
		<string>comgooglemaps</string>
		<string>waze</string>
		<string>here-location</string>
		<string>yandexmaps</string>
		<string>yandexnavi</string>
		<string>tomtomgo</string>
		<string>citymapper</string>
		<string>com.sygic.aura</string>
		<string>copilot</string>
		<string>moovit</string>
	</array>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<!-- NSCameraUsageDescription intentionally omitted for the MVP: the QR
	     scanner (/scanner) is disabled and no camera is accessed, so no camera
	     permission is declared and none appears in App Store review. Restore
	     this key when re-enabling QR scanning. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Aplikace potřebuje přístup k poloze, aby ji mohla zobrazit na mapě studánek.</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>FlutterSceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
